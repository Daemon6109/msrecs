{
	"name": "msrecs",
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"MSRECSBenchmark": {
				"$path": "benchmark-dist/studio-benchmark.server.luau"
			}
		},
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"MSRECS": {
				"$path": "dist"
			},
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@rbxts": {
						"$path": "node_modules/@rbxts"
					}
				}
			}
		}
	}
}
